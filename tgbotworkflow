    {
      "parameters": {
        "jsCode": "const input = $input.first();\nconst trades = input.json.trade_log;\n\nif (!trades || trades.length === 0) {\n  throw new Error(\"No trade data available\");\n}\n\n// Получаем уникальные тикеры для A и B\nconst tickers = [...new Set(trades.map(t => t.ticker))];\n\n// Если тикеров два, используем их как A и B\n// Если один — дублируем его (для демо)\nlet tickerA = tickers[0];\nlet tickerB = tickers[1] || tickers[0];\n\n// Группируем по дате\nconst dataByDate = {};\n\nfor (const trade of trades) {\n  const date = trade.date;\n  const ticker = trade.ticker;\n  const equity = parseFloat(trade.equity);\n  const price = parseFloat(trade.price);\n  \n  if (!dataByDate[date]) {\n    dataByDate[date] = {\n      date: date,\n      tickerA: { value: null },\n      tickerB: { value: null }\n    };\n  }\n  \n  // Используем equity если есть, иначе price\n  const value = !isNaN(equity) ? equity : (!isNaN(price) ? price : null);\n  \n  if (ticker === tickerA) {\n    dataByDate[date].tickerA.value = value;\n  } else if (ticker === tickerB) {\n    dataByDate[date].tickerB.value = value;\n  }\n}\n\n// Сортируем по дате\nconst dailyData = Object.values(dataByDate).sort((a, b) => \n  new Date(a.date) - new Date(b.date)\n);\n\n// Берем последние 30 дней\nconst last30Days = dailyData.slice(-30);\n\n// Определяем победителя\nconst chartData = last30Days.map(day => {\n  let winner = null;\n  const aVal = day.tickerA.value;\n  const bVal = day.tickerB.value;\n  \n  if (aVal !== null && bVal !== null) {\n    winner = bVal > aVal ? \"B\" : (aVal > bVal ? \"A\" : \"tie\");\n  } else if (aVal !== null) {\n    winner = \"A\";\n  } else if (bVal !== null) {\n    winner = \"B\";\n  }\n  \n  return {\n    date: day.date,\n    value_a: aVal,\n    value_b: bVal,\n    winner: winner,\n    color: winner === \"B\" ? \"blue\" : (winner === \"A\" ? \"red\" : \"gray\")\n  };\n});\n\nconst winsA = chartData.filter(d => d.winner === \"A\").length;\nconst winsB = chartData.filter(d => d.winner === \"B\").length;\n\nreturn [{\n  json: {\n    chart_data: chartData,\n    dates: chartData.map(d => d.date),\n    values_a: chartData.map(d => d.value_a),\n    values_b: chartData.map(d => d.value_b),\n    wins_a: winsA,\n    wins_b: winsB,\n    total_days: chartData.length,\n    ticker_a: tickerA,\n    ticker_b: tickerB,\n    raw_trades: trades.slice(-30)\n  }\n}];"

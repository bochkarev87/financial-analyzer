      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst datasets = [\n  {\n    label: `Variant A (${data.ticker_a})`,\n    data: data.values_a,\n    borderColor: \"#ff4444\",\n    backgroundColor: \"rgba(255, 68, 68, 0.1)\",\n    fill: false,\n    tension: 0.1\n  },\n  {\n    label: `Variant B (${data.ticker_b})`,\n    data: data.values_b,\n    borderColor: \"#4444ff\",\n    backgroundColor: \"rgba(68, 68, 255, 0.1)\",\n    fill: false,\n    tension: 0.1\n  }\n];\n\n// Цветные аннотации для фона\nconst annotations = {};\ndata.chart_data.forEach((day, index) => {\n  if (day.winner === \"A\") {\n    annotations[`bg_${index}`] = {\n      type: \"box\",\n      xMin: index - 0.45,\n      xMax: index + 0.45,\n      backgroundColor: \"rgba(255, 68, 68, 0.35)\",\n      borderWidth: 0\n    };\n  } else if (day.winner === \"B\") {\n    annotations[`bg_${index}`] = {\n      type: \"box\",\n      xMin: index - 0.45,\n      xMax: index + 0.45,\n      backgroundColor: \"rgba(68, 68, 255, 0.35)\",\n      borderWidth: 0\n    };\n  }\n});\n\nconst chartConfig = {\n  type: \"line\",\n  data: {\n    labels: data.dates.map(d => d.slice(5, 10)),\n    datasets: datasets\n  },\n  options: {\n    responsive: true,\n    maintainAspectRatio: true,\n    plugins: {\n      title: {\n        display: true,\n        text: \"📈 A/B Test Results: Last 30 Days\",\n        font: { size: 16 }\n      },\n      subtitle: {\n        display: true,\n        text: `🔴 Red = A wins | 🔵 Blue = B wins`,\n        font: { size: 12 }\n      },\n      tooltip: {\n        mode: \"index\",\n        intersect: false\n      },\n      annotation: {\n        annotations: annotations\n      }\n    },\n    scales: {\n      y: {\n        title: {\n          display: true,\n          text: \"Performance (Equity / Price)\"\n        }\n      },\n      x: {\n        title: {\n          display: true,\n          text: \"Date\"\n        }\n      }\n    }\n  }\n};\n\nreturn [{\n  json: {\n    chart_config: JSON.stringify(chartConfig),\n    wins_a: data.wins_a,\n    wins_b: data.wins_b,\n    total_days: data.total_days,\n    ticker_a: data.ticker_a,\n    ticker_b: data.ticker_b\n  }\n}];"
